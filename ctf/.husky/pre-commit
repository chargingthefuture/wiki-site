# git push --no-verify
#!/bin/sh
set -e
. "$(dirname "$0")/_/husky.sh"

repo_root="$(cd "$(dirname "$0")/.." && pwd)"

echo "Running rewrite typecheck gate..."
cd "$repo_root" || exit 1
pnpm run typecheck

# Block commits that modify the /platform folder
if git diff --cached --name-only | grep -q '^platform/'; then
	echo "ERROR: Commits to the /platform folder are not allowed. This folder is reference-only during migration." >&2
	exit 1
fi

echo "All typechecks passed. Proceeding with commit."
