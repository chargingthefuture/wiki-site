# git push --no-verify
#!/bin/sh
set -e
. "$(dirname "$0")/_/husky.sh"


repo_root="$(git rev-parse --show-toplevel)"

echo "Running rewrite pre-push verification (lint, typecheck, web build)..."
cd "$repo_root" || exit 1

# Run Railway build for web package
cd "$repo_root/ctf/packages/web" || exit 1
echo "Running railway run pnpm build in web package..."
railway run pnpm build
cd "$repo_root"

echo "Pre-push verification passed. Proceeding with push."