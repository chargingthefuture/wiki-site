{
  "name": "ti-skills-economy",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "format:check": "bash ./scripts/check-eof-format.sh",
    "governance:check": "bash ./scripts/check-modularity-governance.sh",
    "dev:web": "pnpm --filter @ctf/web run dev",
    "dev:mobile": "pnpm --filter @ctf/mobile run start"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.20.1",
    "eslint-config-next": "^16.1.6",
    "prettier": "^3.5.0",
    "typescript": "^5.7.3"
  }
}
