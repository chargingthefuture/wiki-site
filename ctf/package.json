{
  "name": "ti-skills-economy",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath ctf/.husky && chmod +x .husky/pre-commit .husky/pre-push || true",
    "build": "pnpm -r --if-present run build",
    "lint": "pnpm -r --if-present --filter=!@ctf/web run lint",
    "verify:web": "pnpm --filter @ctf/web run lint && && pnpm run lint",
    "verify:mobile": "pnpm --filter @ctf/mobile run lint && pnpm --filter @ctf/mobile run build:android:ci && node ./scripts/check-web-android-parity.mjs",
    "verify:pre-push": "pnpm run verify:web && pnpm run verify:mobile",
    "test": "pnpm -r --if-present run test",
    "seed:skills-taxonomy": "node ./scripts/seedSkillsTaxonomyPhase0.mjs",
    "seed:directory": "node ./scripts/seedDirectoryPhase0.mjs",
    "seed:feed-announcements": "node ./scripts/seedFeedAnnouncementsPhase0.mjs",
    "seed:workforce": "node ./scripts/seedWorkforcePhase1.mjs",
    "seed:skills-hunt": "node ./scripts/seedSkillsHuntPhase1.mjs",
    "seed:foundation": "node ./scripts/seedFoundationPhase1.mjs",
    "seed:lighthouse": "node ./scripts/seedLighthousePhase2.mjs",
    "seed:socketrelay": "node ./scripts/seedSocketRelayPhase2.mjs",
    "seed:trusttransport": "node ./scripts/seedTrustTransportPhase2.mjs",
    "seed:levelup": "node ./scripts/seedLevelupPhase3.mjs",
    "sync:skills-taxonomy:legacy": "node ./scripts/syncSkillsTaxonomyFromPlatform.mjs --mode=sync",
    "migrate:file": "node ./scripts/runMigrationFile.mjs",
    "migrate:schema": "node ./scripts/runMigrationFile.mjs --file=./schema.sql",
    "migrate:all": "pnpm run migrate:schema",
    "schema:report-live-drift": "bash ./scripts/audit_schema_drift.sh",
    "schema:audit-queries": "node ./scripts/audit-schema-queries.mjs",

    "formance:fetch:standalone": "node ./scripts/fetchFormanceStandalone.mjs",
    "formance:up:standalone": "pnpm run formance:fetch:standalone && docker compose -f ./ops/formance/upstream-standalone/docker-compose.yml up -d",
    "formance:down:standalone": "bash ./scripts/formanceStandaloneDown.sh",
    "formance:ps:standalone": "pnpm run formance:fetch:standalone && docker compose -f ./ops/formance/upstream-standalone/docker-compose.yml ps",
    "formance:bootstrap:railway": "bash ./scripts/formanceRailwayBootstrap.sh",
    "format:check": "bash ./scripts/check-eof-format.sh",
    "governance:check": "bash ./scripts/check-modularity-governance.sh",
    "perf:budgets": "node ./scripts/performanceBudgetAudit.mjs --mode=warn --output=./artifacts/performance/perf-budget-report.json",
    "perf:budgets:ci": "PERF_BUDGET_MODE=warn PERF_BUDGET_OUTPUT_PATH=./artifacts/performance/perf-budget-report.json node ./scripts/performanceBudgetAudit.mjs",
    "dev:web": "pnpm --filter @ctf/web run dev",
    "dev:mobile": "pnpm --filter @ctf/mobile run start"
  },
  "dependencies": {
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.20.1",
    "eslint-config-next": "^16.1.6",
    "husky": "^9.1.7",
    "prettier": "^3.5.0",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1.1.12": "1.1.13",
      "brace-expansion@5.0.4": "5.0.5",
      "minimatch@3.1.2": "3.1.4",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4",
      "yaml@2.8.2": "2.8.3"
    }
  }
}
