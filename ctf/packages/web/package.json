{
  "name": "@ctf/web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "NEXT_TELEMETRY_DISABLED=1 next dev",
    "build": "NEXT_TELEMETRY_DISABLED=1 NODE_OPTIONS=--max-old-space-size=8192 NEXT_PRIVATE_MAX_WORKER_THREADS=1 SENTRY_SUPPRESS_GLOBAL_ERROR_HANDLER_FILE_WARNING=1 next build",
    "build:ci": "NEXT_TELEMETRY_DISABLED=1 CTF_SKIP_SENTRY_NEXTJS=1 NODE_OPTIONS=--max-old-space-size=8192 NEXT_PRIVATE_MAX_WORKER_THREADS=1 SENTRY_SUPPRESS_GLOBAL_ERROR_HANDLER_FILE_WARNING=1 next build",
    "lint": "eslint app components lib src global-error.js global-error.ts instrumentation.ts sentry.edge.config.ts sentry.server.config.ts eslint.config.mjs --max-warnings=0",
    "start": "NEXT_TELEMETRY_DISABLED=1 next start -p ${PORT:-3000}",
    "check:all": "pnpm run lint && pnpm run typecheck && pnpm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check:auth-env": "node ./scripts/check-auth-env.mjs",
    "check:clerk-env": "node ./scripts/check-auth-env.mjs",
    "check:formance-env": "node ./scripts/check-formance-env.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@sentry/nextjs": "^10.21.0",
    "@tailwindcss/postcss": "^4.2.2",
    "lucide-react": "^1.6.0",
    "next": "^15.5.14",
    "node-cron": "^3.0.0",
    "pg": "^8.16.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stream-chat": "^8.60.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.5.14",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.0"
  }
}
