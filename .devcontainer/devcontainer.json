{
  "name": "ChargingTheFuture",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20-bullseye",
  "containerEnv": {
    "CTF_CODESPACES_FAST_MODE": "1",
    "CTF_SKIP_SENTRY_NEXTJS": "1"
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli": {}
  },
  "postCreateCommand": "git config --global user.email '16567092+farahbrunache@users.noreply.github.com' && git config --global user.name 'Farah Brunache' && bash .devcontainer/setup.sh",
  "forwardPorts": [3000, 8081, 19000, 19001],
  "portsAttributes": {
    "3000": {
      "label": "Web App",
      "onAutoForward": "notify"
    },
    "8081": {
      "label": "Metro Bundler",
      "onAutoForward": "notify"
    },
    "19000": {
      "label": "Expo",
      "onAutoForward": "notify"
    },
    "19001": {
      "label": "Expo DevTools",
      "onAutoForward": "notify"
    }
  }
}
