{
    // Reduce file system watchers for performance
    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/dist/**": true,
        "**/.git/**": true,
        "**/.next/**": true,
        "**/.pnpm/**": true
    },
    // Lower memory for large files
    "files.maxMemoryForLargeFilesMB": 16,
    // Disable following symlinks in search
    "search.followSymlinks": false,
    // Use minimal tree indent
    "workbench.tree.indent": 8,
    "editor.minimap.enabled": false,
    // Limit open editors
    "workbench.editor.limit.value": 1,
    // Disable smooth scrolling for less GPU/memory
    "editor.smoothScrolling": false,
    // Hide breadcrumbs
    "breadcrumbs.enabled": false,
    // Hide unused side bar
    "workbench.sideBar.location": "right",
    // Lower tab close delay
    "workbench.editor.closeOnFileDelete": true,
    "workbench.colorTheme": "Dark+",
    "editor.fontSize": 18,
    "editor.fontFamily": "Fira Code, Menlo, Monaco, 'Courier New', monospace",
    "editor.lineHeight": 26,
    "editor.cursorBlinking": "phase",
    
    "editor.renderWhitespace": "none",
    "editor.bracketPairColorization.enabled": false,
    "editor.scrollbar.vertical": "hidden",    
    "workbench.colorCustomizations": {
        "editor.background": "#20242b",
        "editor.foreground": "#b9c1c9",
        "editorLineNumber.foreground": "#727b86",
        "editorLineNumber.activeForeground": "#afb8c1",
        "editorCursor.foreground": "#aab3bd",
        "editor.selectionBackground": "#36424f66",
        "editor.linkedEditingBackground": "#5f6f7f24",
        "statusBar.background": "#1b1f24",
        "statusBar.foreground": "#bfc7cf",
        "titleBar.activeBackground": "#1b1f24",
        "titleBar.activeForeground": "#bfc7cf",
        "sideBar.background": "#1b1f24",
        "sideBar.foreground": "#bfc7cf"
    },
    "python-envs.defaultEnvManager": "ms-python.python:system",

    "npm.autoDetect": "off",
    "npm.enableScriptExplorer": false,

    "workbench.editor.enablePreview": true,
    "workbench.editor.enablePreviewFromCodeNavigation": true,
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.perEditorGroup": true,
    "workbench.editor.limit.value": 1,
    "workbench.editor.limit.excludeDirty": true,
    "workbench.activityBar.location": "hidden",
    "extensions.autoUpdate": false,
    "extensions.ignoreRecommendations": true,
    "workbench.extensions.showRecommendationsOnInstall": false,
      "workbench.layout.activityBar.location": "side",
  "workbench.sideBar.location": "right",
  "workbench.editor.showTabs": true,
  "workbench.panel.defaultLocation": "bottom",
  "workbench.panel.opensMaximized": false,
  "workbench.panel.size": 300,
  "terminal.integrated.defaultLocation": "bottom",
  "terminal.integrated.splitCside": "horizontal",
  "markdown.preview.breaks": true,
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "markdown.extension.preview.autoShowPreviewToSide": true,
  "files.autoSave": "afterDelay",
  "editor.minimap.enabled": false,
  "editor.wordWrap": "on",
  "workbench.startupEditor": "none"
}
